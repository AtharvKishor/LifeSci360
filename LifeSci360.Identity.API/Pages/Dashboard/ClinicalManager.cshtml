@page
@model LifeSci360.Identity.API.Pages.Dashboard.ClinicalManagerModel
@{
    Layout = null;
    int pNum = 1;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Clinical Trial Manager — LifeSci360</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body style="background:#f0f2f5">

    <nav class="navbar bg-white shadow-sm px-4">
        <span class="fw-bold text-primary">LifeSci360</span>
        <span class="text-muted small ms-2">/ Clinical Trial Manager</span>
        <div class="ms-auto d-flex gap-2">
            <a asp-page="/Dashboard/EnrollPatient"
                   class="btn btn-primary btn-sm">
                + Enroll Patient
            </a>
            <form method="post" asp-page="/Account/Logout">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger btn-sm">Logout</button>
            </form>
        </div>
    </nav>

    <div class="container-fluid px-4 py-4">

        <div class="mb-4">
            <h5 class="fw-semibold mb-1">Clincial Manager Dashboard</h5>
            <p class="text-muted mb-0">
                Manage enrolled patients and visit schedules.
            </p>
           <p class="mt-1">For Protocol Registration and Site Setup <a href="/Dashboard/ClinicalManagerProtocol" >Click Here</a></p> 
        </div>

        <div class="mb-4">

        </div>
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small">Total Patients</div>
                        <h3 class="">@Model.TotalPatients</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small">Active Patients</div>
                        <h3 class="">@Model.ActivePatients</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small">Completed Patients</div>
                        <h3 class="">@Model.CompletedPatients</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small">Withdrawn</div>
                        <h3 class="">@Model.WithdrawnCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3
                d-flex justify-content-between align-items-center">
                <h6 class="fw-semibold mb-0">Patient List</h6>
                <input type="text" id="searchInput"
                       class="form-control form-control-sm"
                       style="width:220px"
                       placeholder="Search patients..." />
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0"
                       id="patientTable">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 small fw-semibold">Patient ID</th>
                            <th class="small fw-semibold">Name</th>
                            <th class="small fw-semibold">Contact</th>
                            <th class="small fw-semibold">Status</th>
                            <th class="small fw-semibold">Enrolled Date</th>
                            <th class="small fw-semibold text-end pe-4">
                                Actions
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Patients
                            .OrderBy(x => x.EnrolledDate))
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle bg-primary
                                            bg-opacity-10 d-flex
                                            align-items-center
                                            justify-content-center"
                                             style="width:34px;height:34px;
                                            font-size:12px;font-weight:500;
                                            color:#0d6efd;">
                                            @p.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="small fw-semibold">
                                            P@(pNum)
                                        </span>
                                    </div>
                                </td>
                                <td class="small">@p.FullName</td>
                                <td class="small text-muted">
                                    @(p.ContactInfo ?? "—")
                                </td>
                                <td>
                                    @if (p.Status == "Withdrawn")
                                    {
                                        <span class="badge bg-danger
                                            bg-opacity-10 text-danger
                                            px-2 py-1 small">
                                            Withdrawn
                                        </span>
                                    }
                                    else if (Model.CompletedPatientIds
                                        .Contains(p.PatientID))
                                    {
                                        <span class="badge bg-secondary
                                            bg-opacity-10 text-secondary
                                            px-2 py-1 small">
                                            Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success
                                            bg-opacity-10 text-success
                                            px-2 py-1 small">
                                            Active
                                        </span>
                                    }
                                </td>
                                <td class="small text-muted">
                                    @p.EnrolledDate.ToString("dd MMM yyyy")
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a asp-page="/Dashboard/PatientVisits"
                                               asp-route-patientId="@p.PatientID"
                                               class="btn btn-outline-primary btn-sm">
                                            View Visits
                                        </a>
                                        @if (p.Status == "Enrolled" &&
                                             !Model.CompletedPatientIds
                                                .Contains(p.PatientID))
                                        {
                                            <form method="post"
                                                  asp-page-handler="Withdraw"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Withdraw @p.FullName from the trial?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden"
                                                       name="patientId"
                                                       value="@p.PatientID" />
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-sm">
                                                    Withdraw
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                            pNum++;
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('searchInput')
        .addEventListener('keyup', function() {
        const filter = this.value.toLowerCase();
        document.querySelectorAll('#patientTable tbody tr')
        .forEach(row => {
        row.style.display =
        row.innerText.toLowerCase()
        .includes(filter) ? '' : 'none';
        });
        });
    </script>
</body>
</html>