@page
@model LifeSci360.Identity.API.Pages.Dashboard.ClinicalManagerModel
@{
    ViewData["Title"] = "Clinical Manager";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clinical Manager — LifeSci360</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f4f6f9; min-height: 100vh; font-size: 14px; }
        .topbar { background: #fff; border-bottom: 1px solid #e0e4ea;
                  padding: 0.75rem 1.5rem; }
        .brand { font-weight: 700; color: #0d6efd; font-size: 1rem; }
        .stat-card { background: #fff; border: 1px solid #e2e5ea;
                     border-radius: 8px; padding: 1rem 1.25rem; }
        .stat-label { font-size: 11px; color: #999;
                      text-transform: uppercase; letter-spacing: 0.5px;
                      margin-bottom: 6px; }
        .stat-value { font-size: 2rem; font-weight: 700; line-height: 1; }
        .main-card { background: #fff; border: 1px solid #e2e5ea;
                     border-radius: 8px; overflow: hidden; }
        .toolbar { padding: 0.75rem 1rem; border-bottom: 1px solid #eee;
                   display: flex; align-items: center;
                   justify-content: space-between; background: #fafafa; }
        .table th { font-size: 11px; color: #888; font-weight: 600;
                    text-transform: uppercase; letter-spacing: 0.4px;
                    padding: 0.6rem 1rem; border-bottom: 1px solid #eee;
                    background: #fafafa; }
        .table td { font-size: 13px; padding: 0.7rem 1rem;
                    vertical-align: middle; border-color: #f5f5f5; }
        .table tbody tr:hover { background: #fafbff; }
        .badge-status { font-size: 11px; font-weight: 500;
                        padding: 3px 9px; border-radius: 4px; }
        .site-tag { display: inline-flex; align-items: center;
                    gap: 3px; font-size: 11px; padding: 2px 7px;
                    border-radius: 3px; margin: 1px; border: 1px solid; }
        .form-label { font-size: 12px; color: #555;
                      margin-bottom: 3px; font-weight: 500; }
        .form-control, .form-select { font-size: 13px;
                                      border-color: #ddd;
                                      border-radius: 6px; }
        .form-control:focus, .form-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 2px rgba(13,110,253,0.1); }
        .modal-section-label { font-size: 11px; font-weight: 600;
                               color: #888; text-transform: uppercase;
                               letter-spacing: 0.5px; margin-bottom: 10px; }
        .detail-key { font-size: 11px; color: #999;
                      text-transform: uppercase; letter-spacing: 0.3px;
                      margin-bottom: 3px; }
        .detail-val { font-size: 13px; color: #222; font-weight: 500; }
        .site-detail-card { border: 1px solid #eee; border-radius: 6px;
                            padding: 0.75rem; margin-bottom: 0.5rem; }
        .inv-avatar { width: 30px; height: 30px; border-radius: 50%;
                      background: #e8f0fe; color: #3b5bdb;
                      display: inline-flex; align-items: center;
                      justify-content: center; font-size: 11px;
                      font-weight: 700; flex-shrink: 0; }
        .edit-tabs .nav-link { font-size: 13px; padding: 0.4rem 1rem;
                               color: #666; }
        .edit-tabs .nav-link.active { color: #0d6efd;
                                      border-bottom: 2px solid #0d6efd; }
        .tab-pane { padding-top: 1rem; }
        .status-info { background: #f0f5ff; border: 1px solid #c7d7f5;
                       border-radius: 6px; padding: 0.5rem 0.75rem;
                       font-size: 12px; color: #555; }
        .search-box { position: relative; }
        .search-box input { padding: 5px 10px 5px 30px;
                            border: 1px solid #ddd; border-radius: 6px;
                            font-size: 13px; width: 220px;
                            outline: none; background: #fafafa; }
        .search-box input:focus { border-color: #0d6efd;
                                  background: #fff; }
        .search-box svg { position: absolute; left: 8px; top: 50%;
                          transform: translateY(-50%);
                          pointer-events: none; }
    </style>
</head>
<body>

    <!-- Topbar -->
    <div class="topbar d-flex align-items-center
                justify-content-between">
        <div class="d-flex align-items-center gap-3">
            <span class="brand">LifeSci360</span>
            <span class="text-muted" style="font-size:13px">
                Clinical Manager
            </span>
        </div>
        <form method="post" asp-page="/Account/Logout">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="btn btn-outline-danger btn-sm">
                Logout
            </button>
        </form>
    </div>

    <div class="container-fluid px-4 py-4" style="max-width:1300px">

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible
                        fade show py-2 mb-3" style="font-size:13px">
                @Model.SuccessMessage
                <button type="button" class="btn-close"
                        data-bs-dismiss="alert"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible
                        fade show py-2 mb-3" style="font-size:13px">
                @Model.ErrorMessage
                <button type="button" class="btn-close"
                        data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Heading -->
        <div class="mb-4">
            <h5 class="fw-bold mb-0">Clinical Manager Dashboard</h5>
            <p class="text-muted mb-0" style="font-size:13px">
                Manage protocols, sites and investigators
            </p> 
                       <p class="mt-1">For Patients Enrollment & Visit Schedules <a href="/Dashboard/ClinicalManager" >Click Here</a></p>
        </div>

        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Total Protocols</div>
                    <div class="stat-value">@Model.Protocols.Count</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Active</div>
                    <div class="stat-value text-success">
                        @Model.ActiveCount
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Inactive</div>
                    <div class="stat-value text-warning">
                        @Model.InactiveCount
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-label">Completed</div>
                    <div class="stat-value text-secondary">
                        @Model.CompletedCount
                    </div>
                </div>
            </div>
        </div>

        <!-- Protocols Table -->
        <div class="main-card">
            <div class="toolbar">
                <span style="font-size:13px; font-weight:600;
                             color:#333">
                    Protocols
                </span>
                <div class="d-flex align-items-center gap-2">
                    <div class="search-box">
                        <svg width="14" height="14"
                             viewBox="0 0 16 16" fill="none">
                            <circle cx="6.5" cy="6.5" r="5"
                                    stroke="#aaa" stroke-width="1.5"/>
                            <path d="M10.5 10.5L14 14"
                                  stroke="#aaa" stroke-width="1.5"
                                  stroke-linecap="round"/>
                        </svg>
                        <input type="text" id="searchInput"
                               placeholder="Search protocols..."
                               onkeyup="filterTable()" />
                    </div>
                    <button type="button"
                            class="btn btn-primary btn-sm"
                            data-bs-toggle="modal"
                            data-bs-target="#createModal">
                        + Create Protocol
                    </button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table mb-0" id="protocolTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th>Phase Type</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Sites</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Protocols.Any())
                        {
                            <tr>
                                <td colspan="8"
                                    class="text-center py-4 text-muted">
                                    No protocols found. Click
                                    "+ Create Protocol" to begin.
                                </td>
                            </tr>
                        }
                        @foreach (var p in Model.Protocols)
                        {
                            <tr>
                                <td class="text-muted"
                                    style="font-size:12px">
                                    #@p.ProtocolID
                                </td>
                                <td>
                                    <div class="fw-semibold">
                                        @p.Title
                                    </div>
                                    @if (!string.IsNullOrEmpty(
                                        p.Description))
                                    {
                                        <div class="text-muted"
                                             style="font-size:11px">
                                            @p.Description
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="badge badge-status
                                          @Model.GetProtocolBadge(
                                              p.Status)">
                                        @p.Status
                                    </span>
                                </td>
                                <td style="font-size:13px">
                                    @p.Phase
                                </td>
                                <td class="text-muted"
                                    style="font-size:12px">
                                    @(p.StartDate.ToString("dd MMM yyyy"))
                                </td>
                                <td class="text-muted"
                                    style="font-size:12px">
                                    @(p.EndDate.ToString("dd MMM yyyy"))
                                </td>
                                <td style="min-width:140px">
                                    @if (!p.Sites.Any())
                                    {
                                        <span class="text-muted"
                                              style="font-size:12px">
                                            No sites
                                        </span>
                                    }
                                    else
                                    {
                                        @foreach (var s in p.Sites)
                                        {
                                            <div style="margin-bottom:2px">
                                                <span class="site-tag
                                                      @Model.GetSiteBadge(
                                                          s.Status)">
                                                    @s.Name
                                                </span>
                                            </div>
                                        }
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <button type="button"
                                                class="btn btn-sm
                                                btn-outline-secondary"
                                                style="font-size:11px;
                                                padding:2px 8px"
                                                data-bs-toggle="modal"
                                                data-bs-target="#view-@p.ProtocolID">
                                            View
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm
                                                btn-outline-primary"
                                                style="font-size:11px;
                                                padding:2px 8px"
                                                data-bs-toggle="modal"
                                                data-bs-target="#edit-@p.ProtocolID">
                                            Edit
                                        </button>
                                        <button type="button"
                class="btn btn-sm btn-outline-success"
                style="font-size:11px; padding:2px 8px"
                data-bs-toggle="modal"
                data-bs-target="#addSite-@p.ProtocolID">
            + Site
        </button>
                                        <button type="button"
                                                class="btn btn-sm
                                                btn-outline-danger"
                                                style="font-size:11px;
                                                padding:2px 8px"
                                                data-bs-toggle="modal"
                                                data-bs-target="#delProt-@p.ProtocolID">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- CREATE PROTOCOL MODAL -->
    <div class="modal fade" id="createModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 shadow-sm">
                <div class="modal-header py-3">
                    <h6 class="modal-title fw-semibold mb-0">
                        Create Protocol
                    </h6>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <form method="post"
                      asp-page-handler="CreateProtocol">
                    @Html.AntiForgeryToken()
                    <div class="modal-body px-4 py-3">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Title</label>
                                <input type="text" name="Title"
                                       class="form-control"
                                       placeholder="Protocol title"
                                       required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">
                                    Phase Type
                                </label>
                                <select name="Phase"
                                        class="form-select">
                                    <option>Phase I</option>
                                    <option>Phase II</option>
                                    <option>Phase III</option>
                                    <option>Phase IV</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">
                                    Description
                                    <span class="text-muted fw-normal">
                                        (optional)
                                    </span>
                                </label>
                                <input type="text" name="Description"
                                       class="form-control"
                                       placeholder="Brief description" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">
                                    Start Date
                                </label>
                                <input type="date" name="StartDate"
                                       class="form-control"
                                     
                                       max="@Model.MaxDateString"
                                       required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">
                                    End Date
                                </label>
                                <input type="date" name="EndDate"
                                       class="form-control"
                                       
                                       max="@Model.MaxDateString"
                                       required />
                            </div>
                            <div class="col-12">
                                <div class="status-info">
                                    Status is set automatically —
                                    <strong>Inactive</strong> if start
                                    date is future,
                                    <strong>Active</strong> if within
                                    dates, <strong>Completed</strong>
                                    if end date has passed.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit"
                                class="btn btn-sm btn-primary px-4">
                            Create Protocol
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!--PER-PROTOCOL MODALS -->
    @foreach (var p in Model.Protocols)
    {
        <!-- VIEW MODAL -->
        <div class="modal fade"
             id="view-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog modal-lg
                        modal-dialog-scrollable">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header py-3">
                        <div>
                            <h6 class="modal-title fw-semibold mb-1">
                                @p.Title
                            </h6>
                            <span class="badge badge-status
                                  @Model.GetProtocolBadge(p.Status)">
                                @p.Status
                            </span>
                        </div>
                        <button type="button" class="btn-close"
                                data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4 py-3">

                        <p class="modal-section-label">
                            Protocol Information
                        </p>
                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <div class="detail-key">Protocol ID</div>
                                <div class="detail-val">
                                    #@p.ProtocolID
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="detail-key">Phase Type</div>
                                <div class="detail-val">@p.Phase</div>
                            </div>
                            <div class="col-md-3">
                                <div class="detail-key">Start Date</div>
                                <div class="detail-val">
                                    @(p.StartDate.ToString("dd MMM yyyy"))
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="detail-key">End Date</div>
                                <div class="detail-val">
                                    @(p.EndDate.ToString("dd MMM yyyy"))
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="detail-key">Duration</div>
                                <div class="detail-val">
                                    @((p.EndDate - p.StartDate).Days)
                                    days
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="detail-key">Created</div>
                                <div class="detail-val">
                                    @(p.CreatedDate.ToString(
                                        "dd MMM yyyy"))
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="col-12">
                                    <div class="detail-key">
                                        Description
                                    </div>
                                    <div class="detail-val fw-normal
                                                text-muted">
                                        @p.Description
                                    </div>
                                </div>
                            }
                        </div>

                        <p class="modal-section-label">
                            Sites &amp; Investigators
                        </p>
                        @if (!p.Sites.Any())
                        {
                            <p class="text-muted small">
                                No sites assigned.
                            </p>
                        }
                        else
                        {
                            <div class="row g-2">
                                @foreach (var s in p.Sites)
                                {
                                    <div class="col-md-6">
                                        <div class="site-detail-card">
                                            <div class="d-flex
                                                 justify-content-between
                                                 align-items-start mb-2">
                                                <div>
                                                    <div class="fw-semibold"
                                                         style="font-size:13px">
                                                        @s.Name
                                                    </div>
                                                    <div class="text-muted"
                                                         style="font-size:12px">
                                                        @s.Location
                                                    </div>
                                                </div>
                                                <span class="badge
                                                      badge-status
                                                      @Model.GetSiteBadge(
                                                          s.Status)">
                                                    @s.Status
                                                </span>
                                            </div>
                                            <div class="pt-2"
                                                 style="border-top:
                                                 1px solid #f0f0f0">
                                                <div class="detail-key mb-1">
                                                    Investigator
                                                </div>
                                                @if (s.Investigator != null)
                                                {
                                                    <div class="d-flex
                                                         align-items-center
                                                         gap-2">
                                                        <div class="inv-avatar">
                                                            @Model.GetInitial(
                                                                s.Investigator.FullName)
                                                        </div>
                                                        <div>
                                                            <div class="fw-semibold"
                                                                 style="font-size:12px">
                                                                @s.Investigator.FullName
                                                            </div>
                                                            <div class="text-muted"
                                                                 style="font-size:11px">
                                                                @s.Investigator.Email
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted"
                                                          style="font-size:12px;
                                                          font-style:italic">
                                                        Not assigned
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- EDIT MODAL -->
        <div class="modal fade"
             id="edit-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog modal-lg
                        modal-dialog-scrollable">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header py-3">
                        <h6 class="modal-title fw-semibold mb-0">
                            Edit — @p.Title
                        </h6>
                        <button type="button" class="btn-close"
                                data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4 py-3">
                        <ul class="nav nav-tabs edit-tabs mb-0">
                            <li class="nav-item">
                                <button class="nav-link active"
                                        data-bs-toggle="tab"
                                        data-bs-target="#tProt-@p.ProtocolID">
                                    Edit Protocol
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link"
                                        data-bs-toggle="tab"
                                        data-bs-target="#tSite-@p.ProtocolID">
                                    Edit Sites (@p.Sites.Count)
                                </button>
                            </li>
                        </ul>
                        <div class="tab-content">

                            <!-- Tab 1: Edit Protocol -->
                            <div class="tab-pane fade show active"
                                 id="tProt-@p.ProtocolID">
                                <form method="post"
                                      asp-page-handler="EditProtocol">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden"
                                           name="EditProtocolID"
                                           value="@p.ProtocolID" />
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label">
                                                Title
                                            </label>
                                            <input type="text"
                                                   name="EditTitle"
                                                   class="form-control"
                                                   value="@p.Title"
                                                   required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">
                                                Phase Type
                                            </label>
                                            <select name="EditPhase"
                                                    class="form-select">
                                                @foreach (var ph in new[]
                                                {
                                                    "Phase I",
                                                    "Phase II",
                                                    "Phase III",
                                                    "Phase IV"
                                                })
                                                {
                                                    if (ph == p.Phase)
                                                    {
                                                        <option selected>
                                                            @ph
                                                        </option>
                                                    }
                                                    else
                                                    {
                                                        <option>@ph</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">
                                                Description
                                            </label>
                                            <input type="text"
                                                   name="EditDescription"
                                                   class="form-control"
                                                   value="@p.Description"
                                                   placeholder="Optional" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">
                                                Start Date
                                            </label>
                                            <input type="date"
                                                   name="EditStartDate"
                                                   class="form-control"
                                                  
                                                   max="@Model.MaxDateString"
                                                   value="@(p.StartDate.ToString("yyyy-MM-dd"))"
                                                   required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">
                                                End Date
                                            </label>
                                            <input type="date"
                                                   name="EditEndDate"
                                                   class="form-control"
                                                  
                                                   max="@Model.MaxDateString"
                                                   value="@(p.EndDate.ToString("yyyy-MM-dd"))"
                                                   required />
                                        </div>
                                        <div class="col-12">
                                            <div class="status-info">
                                                Current status:
                                                <strong>@p.Status</strong>
                                                — recalculated automatically
                                                after save.
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <button type="submit"
                                                    class="btn btn-primary
                                                    btn-sm px-4">
                                                Save Protocol
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            <!-- Tab 2: Edit Sites -->
                            <div class="tab-pane fade"
                                 id="tSite-@p.ProtocolID">
                                @if (!p.Sites.Any())
                                {
                                    <p class="text-muted small py-3">
                                        No sites added yet.
                                    </p>
                                }
                                else
                                {
                                    @foreach (var s in p.Sites)
                                    {
                                        <div class="site-detail-card mb-3">
                                            <div class="d-flex
                                                 justify-content-between
                                                 align-items-center mb-2">
                                                <div class="fw-semibold"
                                                     style="font-size:13px">
                                                    @s.Name
                                                    <span class="text-muted
                                                          fw-normal ms-1"
                                                          style="font-size:12px">
                                                        — @s.Location
                                                    </span>
                                                </div>
                                                <form method="post"
                                                      asp-page-handler="DeleteSite"
                                                      onsubmit="return confirm('Delete site @Html.Raw(s.Name.Replace("'","\\'"))?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden"
                                                           name="siteId"
                                                           value="@s.SiteID" />
                                                    <button type="submit"
                                                            class="btn btn-sm
                                                            btn-outline-danger"
                                                            style="font-size:11px;
                                                            padding:2px 8px">
                                                        Delete Site
                                                    </button>
                                                </form>
                                            </div>
                                            <form method="post"
                                                  asp-page-handler="EditSite">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden"
                                                       name="EditSiteID"
                                                       value="@s.SiteID" />
                                                <input type="hidden"
                                                       name="EditSiteProtocolID"
                                                       value="@p.ProtocolID" />
                                                <div class="row g-2">
                                                    <div class="col-md-4">
                                                        <label class="form-label">
                                                            Site Name
                                                        </label>
                                                        <input type="text"
                                                               name="EditSiteName"
                                                               class="form-control
                                                                      form-control-sm"
                                                               value="@s.Name"
                                                               required />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label">
                                                            Location
                                                        </label>
                                                        <input type="text"
                                                               name="EditSiteLocation"
                                                               class="form-control
                                                                      form-control-sm"
                                                               value="@s.Location"
                                                               required />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label">
                                                            Status
                                                        </label>
                                                        <select name="EditSiteStatus"
                                                                class="form-select
                                                                       form-select-sm">
                                                            @foreach (var st
                                                                in new[]
                                                                {
                                                                    "Active",
                                                                    "Inactive",
                                                                    "Closed"
                                                                })
                                                            {
                                                                if (st == s.Status)
                                                                {
                                                                    <option selected>
                                                                        @st
                                                                    </option>
                                                                }
                                                                else
                                                                {
                                                                    <option>
                                                                        @st
                                                                    </option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-8">
                                                        <label class="form-label">
                                                            Investigator
                                                        </label>
                                                        <select
                                                            name="EditSiteInvestigatorID"
                                                            class="form-select
                                                                   form-select-sm">
                                                            <option value="">
                                                                None
                                                            </option>
                                                            @foreach (var u in
                                                                Model.Investigators)
                                                            {
                                                                var taken =
                                                                    Model.AssignedInvestigatorIDs
                                                                    .Contains(u.Id)
                                                                    && s.InvestigatorID
                                                                    != u.Id;
                                                                if (!taken)
                                                                {
                                                                    if (s.InvestigatorID
                                                                        == u.Id)
                                                                    {
                                                                        <option
                                                                            value="@u.Id"
                                                                            selected>
                                                                            @u.FullName
                                                                        </option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option
                                                                            value="@u.Id">
                                                                            @u.FullName
                                                                        </option>
                                                                    }
                                                                }
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-4
                                                         d-flex
                                                         align-items-end">
                                                        <button type="submit"
                                                                class="btn
                                                                btn-primary
                                                                btn-sm w-100">
                                                            Save Site
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    }
                                }
                            </div>

                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ADD SITE MODAL -->
        <div class="modal fade"
             id="addSite-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header py-3">
                        <h6 class="modal-title fw-semibold mb-0">
                            Add Site — @p.Title
                        </h6>
                        <button type="button" class="btn-close"
                                data-bs-dismiss="modal"></button>
                    </div>
                    <form method="post"
                          asp-page-handler="AddSite">
                        @Html.AntiForgeryToken()
                        <input type="hidden"
                               name="SiteProtocolID"
                               value="@p.ProtocolID" />
                        <div class="modal-body px-4 py-3">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">
                                        Site Name
                                    </label>
                                    <input type="text"
                                           name="SiteName"
                                           class="form-control"
                                           placeholder="e.g. Chennai Research Centre"
                                           required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">
                                        Location
                                    </label>
                                    <input type="text"
                                           name="SiteLocation"
                                           class="form-control"
                                           placeholder="e.g. Chennai, Tamil Nadu"
                                           required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">
                                        Investigator
                                        
                                    </label>
                                    <select name="SiteInvestigatorID"
                                            class="form-select">
                                        <option value="">
                                            Select Investigator
                                        </option>
                                        @foreach (var u in
                                            Model.Investigators)
                                        {
                                            var alreadyUsed =
                                                Model.AssignedInvestigatorIDs
                                                .Contains(u.Id);
                                            if (!alreadyUsed)
                                            {
                                                <option value="@u.Id">
                                                    @u.FullName
                                                    (@u.Email)
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@u.Id"
                                                        disabled>
                                                    @u.FullName
                                                    (already assigned)
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer py-2">
                            <button type="button"
                                    class="btn btn-sm
                                    btn-outline-secondary"
                                    data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <button type="submit"
                                    class="btn btn-sm
                                    btn-primary px-4">
                                Add Site
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- DELETE PROTOCOL MODAL -->
        <div class="modal fade"
             id="delProt-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header py-3">
                        <h6 class="modal-title fw-semibold mb-0">
                            Delete Protocol
                        </h6>
                        <button type="button" class="btn-close"
                                data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4 py-3">
                        <p style="font-size:13px">
                            Are you sure you want to delete
                            <strong>@p.Title</strong>?
                            This will also delete all
                            <strong>@p.Sites.Count site(s)</strong>
                            attached. This cannot be undone.
                        </p>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <form method="post"
                              asp-page-handler="DeleteProtocol">
                            @Html.AntiForgeryToken()
                            <input type="hidden"
                                   name="protocolId"
                                   value="@p.ProtocolID" />
                            <button type="submit"
                                    class="btn btn-sm btn-danger px-3">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function filterTable() {
            const val = document.getElementById('searchInput')
                            .value.toLowerCase();
            document.querySelectorAll('#protocolTable tbody tr')
                .forEach(row => {
                    row.style.display =
                        row.innerText.toLowerCase().includes(val)
                        ? '' : 'none';
                });
        }
    </script>
</body>
</html>