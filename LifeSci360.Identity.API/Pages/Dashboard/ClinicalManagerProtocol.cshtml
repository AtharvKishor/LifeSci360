@page
@model LifeSci360.Identity.API.Pages.Dashboard.ClinicalManagerModels
@{
    ViewData["Title"] = "Clinical Manager";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clinical Manager — LifeSci360</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body style="background:#f0f2f5">

    <!-- Topbar -->
    <nav class="navbar bg-white shadow-sm px-4">
        <span class="fw-bold text-primary">LifeSci360</span>
        <div class="ms-auto d-flex gap-2">
            <button type="button"
                    class="btn btn-primary btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                + Create Protocol
            </button>
            <form method="post" asp-page="/Account/Login">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    Logout
                </button>
            </form>
        </div>
    </nav>

    <div class="container-fluid px-4 py-4">

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success alert-dismissible fade show py-2 mb-3 small">
                @Model.SuccessMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show py-2 mb-3 small">
                @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Heading -->
        <div class="mb-4">
            <h5 class="fw-semibold mb-1">Clinical Manager Dashboard</h5>
            <p class="text-muted mb-0">Manage protocols, sites and investigators</p>
            <p class="mt-1">
                For Patients Enrollment &amp; Visit Schedules
                <a href="/Dashboard/ClinicalManager">Click Here</a>
            </p>
        </div>

        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small text-uppercase fw-semibold mb-1"
                             style="font-size:11px;letter-spacing:.5px">
                            Total Protocols
                        </div>
                        <h3 class="fw-bold mb-0">@Model.Protocols.Count</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">  
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small text-uppercase fw-semibold mb-1"
                             style="font-size:11px;letter-spacing:.5px">
                            Active Protocols
                        </div>
                        <h3 class="fw-bold mb-0">@Model.ActiveCount</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small text-uppercase fw-semibold mb-1"
                             style="font-size:11px;letter-spacing:.5px">
                            Inactive Protocols
                        </div>
                        <h3 class="fw-bold mb-0">@Model.InactiveCount</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center">
                    <div class="card-body">
                        <div class="text-muted small text-uppercase fw-semibold mb-1"
                             style="font-size:11px;letter-spacing:.5px">
                            Completed Protocols
                        </div>
                        <h3 class="fw-bold mb-0">@Model.CompletedCount</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Protocols Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3
                d-flex justify-content-between align-items-center">
                <h6 class="fw-semibold mb-0">Protocols</h6>
                <input type="text" id="searchInput"
                       class="form-control form-control-sm"
                       style="width:220px"
                       placeholder="Search protocols..."
                       onkeyup="filterTable()" />
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0"
                       id="protocolTable">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 small fw-semibold">Title</th>
                            <th class="small fw-semibold">Status</th>
                            <th class="small fw-semibold">Phase Type</th>
                            <th class="small fw-semibold">Start Date</th>
                            <th class="small fw-semibold">End Date</th>
                            <th class="small fw-semibold">Sites</th>
                            <th class="small fw-semibold text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Protocols.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted small">
                                    No protocols found. Click "+ Create Protocol" to begin.
                                </td>
                            </tr>
                        }
                        @foreach (var p in Model.Protocols)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold small">@p.Title</div>
                                    @if (!string.IsNullOrEmpty(p.Description))
                                    {
                                        <div class="text-muted" style="font-size:11px">
                                            @p.Description
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="badge @Model.GetProtocolBadge(p.Status) px-2 py-1 small">
                                        @p.Status
                                    </span>
                                </td>
                                <td class="small">@p.Phase</td>
                                <td class="small text-muted">
                                    @(p.StartDate.ToString("dd MMM yyyy"))
                                </td>
                                <td class="small text-muted">
                                    @(p.EndDate.ToString("dd MMM yyyy"))
                                </td>
                                <td>
                                    @if (!p.Sites.Any())
                                    {
                                        <span class="text-muted small">No sites</span>
                                    }
                                    else
                                    {
                                        @foreach (var s in p.Sites)
                                        {
                                            <span class="badge @Model.GetSiteBadge(s.Status)
                                                border px-2 py-1 me-1 mb-1 small fw-normal">
                                                @s.Name
                                            </span>
                                        }
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-1 justify-content-end flex-wrap">
                                        <button type="button"
                                                class="btn btn-outline-secondary btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#view-@p.ProtocolID">
                                            View
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-primary btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#edit-@p.ProtocolID">
                                            Edit
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-success btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#addSite-@p.ProtocolID">
                                            + Site
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm"
                                                data-bs-toggle="modal"
                                                data-bs-target="#delProt-@p.ProtocolID">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- CREATE PROTOCOL MODAL -->
    <div class="modal fade" id="createModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 shadow-sm">
                <div class="modal-header">
                    <h6 class="modal-title fw-semibold mb-0">Create Protocol</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" asp-page-handler="CreateProtocol">
                    @Html.AntiForgeryToken()
                    <div class="modal-body px-4 py-3">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Title</label>
                                <input type="text" name="Title" class="form-control"
                                       placeholder="Protocol title" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Phase Type</label>
                                <select name="Phase" class="form-select">
                                    <option>Phase I</option>
                                    <option>Phase II</option>
                                    <option>Phase III</option>
                                    <option>Phase IV</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">
                                    Description
                                    <span class="text-muted fw-normal">(optional)</span>
                                </label>
                                <input type="text" name="Description" class="form-control"
                                       placeholder="Brief description" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">Start Date</label>
                                <input type="date" name="StartDate" class="form-control"
                                       max="@Model.MaxDateString" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-semibold">End Date</label>
                                <input type="date" name="EndDate" class="form-control"
                                       max="@Model.MaxDateString" required />
                            </div>
                            <div class="col-12">
                                <div class="alert alert-info py-2 mb-0 small">
                                    Status is set automatically —
                                    <strong>Inactive</strong> if start date is future,
                                    <strong>Active</strong> if within dates,
                                    <strong>Completed</strong> if end date has passed.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-sm btn-primary px-4">
                            Create Protocol
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- PER-PROTOCOL MODALS -->
    @foreach (var p in Model.Protocols)
    {
        <!-- VIEW MODAL -->
        <div class="modal fade" id="view-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header">
                        <div>
                            <h6 class="modal-title fw-semibold mb-1">@p.Title</h6>
                            <span class="badge @Model.GetProtocolBadge(p.Status) px-2 py-1 small">
                                @p.Status
                            </span>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4 py-3">

                        <p class="text-muted text-uppercase fw-semibold mb-3"
                               style="font-size:11px;letter-spacing:.5px">
                            Protocol Information
                        </p>
                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <div class="text-muted small text-uppercase"
                                     style="font-size:11px">
                                    Phase Type
                                </div>
                                <div class="fw-semibold small">@p.Phase</div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small text-uppercase"
                                     style="font-size:11px">
                                    Start Date
                                </div>
                                <div class="fw-semibold small">
                                    @(p.StartDate.ToString("dd MMM yyyy"))
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small text-uppercase"
                                     style="font-size:11px">
                                    End Date
                                </div>
                                <div class="fw-semibold small">
                                    @(p.EndDate.ToString("dd MMM yyyy"))
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small text-uppercase"
                                     style="font-size:11px">
                                    Duration
                                </div>
                                <div class="fw-semibold small">
                                    @((p.EndDate - p.StartDate).Days) days
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small text-uppercase"
                                     style="font-size:11px">
                                    Created
                                </div>
                                <div class="fw-semibold small">
                                    @(p.CreatedDate.ToString("dd MMM yyyy"))
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="col-12">
                                    <div class="text-muted small text-uppercase"
                                         style="font-size:11px">
                                        Description
                                    </div>
                                    <div class="small text-muted">@p.Description</div>
                                </div>
                            }
                        </div>

                        <p class="text-muted text-uppercase fw-semibold mb-3"
                               style="font-size:11px;letter-spacing:.5px">
                            Sites &amp; Investigators
                        </p>
                        @if (!p.Sites.Any())
                        {
                            <p class="text-muted small">No sites assigned.</p>
                        }
                        else
                        {
                            <div class="row g-2">
                                @foreach (var s in p.Sites)
                                {
                                    <div class="col-md-6">
                                        <div class="border rounded p-3">
                                            <div class="d-flex justify-content-between
                                                align-items-start mb-2">
                                                <div>
                                                    <div class="fw-semibold small">@s.Name</div>
                                                    <div class="text-muted" style="font-size:12px">
                                                        @s.Location
                                                    </div>
                                                </div>
                                                <span class="badge @Model.GetSiteBadge(s.Status)
                                                    px-2 py-1 small">
                                                    @s.Status
                                                </span>
                                            </div>
                                            <div class="pt-2 border-top">
                                                <div class="text-muted small text-uppercase mb-1"
                                                     style="font-size:11px">
                                                    Investigator
                                                </div>
                                                @if (s.InvestigatorID.HasValue)
                                                {
                                                    <span class="small fw-semibold">
                                                        @Model.GetInvestigatorName(s.InvestigatorID)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small fst-italic">
                                                        Not assigned
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- EDIT MODAL -->
        <div class="modal fade" id="edit-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header">
                        <h6 class="modal-title fw-semibold mb-0">Edit — @p.Title</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4 py-3">
                        <ul class="nav nav-tabs mb-0">
                            <li class="nav-item">
                                <button class="nav-link active small"
                                        data-bs-toggle="tab"
                                        data-bs-target="#tProt-@p.ProtocolID">
                                    Edit Protocol
                                </button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link small"
                                        data-bs-toggle="tab"
                                        data-bs-target="#tSite-@p.ProtocolID">
                                    Edit Sites (@p.Sites.Count)
                                </button>
                            </li>
                        </ul>
                        <div class="tab-content pt-3">

                            <!-- Tab 1: Edit Protocol -->
                            <div class="tab-pane fade show active"
                                 id="tProt-@p.ProtocolID">
                                <form method="post" asp-page-handler="EditProtocol">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="EditProtocolID"
                                           value="@p.ProtocolID" />
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label small fw-semibold">
                                                Title
                                            </label>
                                            <input type="text" name="EditTitle"
                                                   class="form-control"
                                                   value="@p.Title" required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-semibold">
                                                Phase Type
                                            </label>
                                            <select name="EditPhase" class="form-select">
                                                @foreach (var ph in new[]
                                                { "Phase I", "Phase II", "Phase III", "Phase IV" })
                                                {
                                                    if (ph == p.Phase)
                                                    {
                                                        <option selected>@ph</option>
                                                    }
                                                    else
                                                    {
                                                        <option>@ph</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-semibold">
                                                Description
                                            </label>
                                            <input type="text" name="EditDescription"
                                                   class="form-control"
                                                   value="@p.Description"
                                                   placeholder="Optional" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-semibold">
                                                Start Date
                                            </label>
                                            <input type="date" name="EditStartDate"
                                                   class="form-control"
                                                   max="@Model.MaxDateString"
                                                   value="@(p.StartDate.ToString("yyyy-MM-dd"))"
                                                   required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-semibold">
                                                End Date
                                            </label>
                                            <input type="date" name="EditEndDate"
                                                   class="form-control"
                                                   max="@Model.MaxDateString"
                                                   value="@(p.EndDate.ToString("yyyy-MM-dd"))"
                                                   required />
                                        </div>
                                        <div class="col-12">
                                            <div class="alert alert-info py-2 mb-0 small">
                                                Current status: <strong>@p.Status</strong>
                                                — recalculated automatically after save.
                                            </div>
                                        </div>
                                        <div class="col-12">
                                            <button type="submit"
                                                    class="btn btn-primary btn-sm px-4">
                                                Save Protocol
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            <!-- Tab 2: Edit Sites -->
                            <div class="tab-pane fade" id="tSite-@p.ProtocolID">
                                @if (!p.Sites.Any())
                                {
                                    <p class="text-muted small py-3">No sites added yet.</p>
                                }
                                else
                                {
                                    @foreach (var s in p.Sites)
                                    {
                                        <div class="border rounded p-3 mb-3">
                                            <div class="d-flex justify-content-between
                                                align-items-center mb-3">
                                                <div class="fw-semibold small">
                                                    @s.Name
                                                    <span class="text-muted fw-normal ms-1 small">
                                                        — @s.Location
                                                    </span>
                                                </div>
                                                <form method="post"
                                                      asp-page-handler="DeleteSite"
                                                      onsubmit="return confirm('Delete site @Html.Raw(s.Name.Replace("'", "\\'"))?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="siteId"
                                                           value="@s.SiteID" />
                                                    <button type="submit"
                                                            class="btn btn-outline-danger btn-sm">
                                                        Delete Site
                                                    </button>
                                                </form>
                                            </div>
                                            <form method="post" asp-page-handler="EditSite">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="EditSiteID"
                                                       value="@s.SiteID" />
                                                <input type="hidden" name="EditSiteProtocolID"
                                                       value="@p.ProtocolID" />
                                                <div class="row g-2">
                                                    <div class="col-md-4">
                                                        <label class="form-label small fw-semibold">
                                                            Site Name
                                                        </label>
                                                        <input type="text" name="EditSiteName"
                                                               class="form-control form-control-sm"
                                                               value="@s.Name" required />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small fw-semibold">
                                                            Location
                                                        </label>
                                                        <input type="text" name="EditSiteLocation"
                                                               class="form-control form-control-sm"
                                                               value="@s.Location" required />
                                                    </div>
                                                    <div class="col-md-4">
                                                        <label class="form-label small fw-semibold">
                                                            Status
                                                        </label>
                                                        <select name="EditSiteStatus"
                                                                class="form-select form-select-sm">
                                                            @foreach (var st in new[]
                                                            { "Active", "Inactive", "Closed" })
                                                            {
                                                                if (st == s.Status)
                                                                {
                                                                    <option selected>@st</option>
                                                                }
                                                                else
                                                                {
                                                                    <option>@st</option>
                                                                }
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-8">
                                                        <label class="form-label small fw-semibold">
                                                            Investigator
                                                        </label>
                                                        <select name="EditSiteInvestigatorID"
                                                                class="form-select form-select-sm">
                                                            <option value="">None</option>
                                                            @foreach (var u in Model.Investigators)
                                                            {
                                                                var taken =
                                                                    Model.AssignedInvestigatorIDs
                                                                    .Contains(u.ID)
                                                                    && s.InvestigatorID?.ToString()
                                                                    != u.ID;
                                                                if (!taken)
                                                                {
                                                                    if (s.InvestigatorID?.ToString()
                                                                        == u.ID)
                                                                    {
                                                                        <option value="@u.ID" selected>
                                                                            @u.FullName
                                                                        </option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="@u.ID">
                                                                            @u.FullName
                                                                        </option>
                                                                    }
                                                                }
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-md-4 d-flex align-items-end">
                                                        <button type="submit"
                                                                class="btn btn-primary btn-sm w-100">
                                                            Save Site
                                                        </button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    }
                                }
                            </div>

                        </div>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Close
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ADD SITE MODAL -->
        <div class="modal fade" id="addSite-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header">
                        <h6 class="modal-title fw-semibold mb-0">
                            Add Site — @p.Title
                        </h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <form method="post" asp-page-handler="AddSite">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SiteProtocolID" value="@p.ProtocolID" />
                        <div class="modal-body px-4 py-3">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label small fw-semibold">Site Name</label>
                                    <input type="text" name="SiteName" class="form-control"
                                           placeholder="e.g. Chennai Research Centre" required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-semibold">Location</label>
                                    <input type="text" name="SiteLocation" class="form-control"
                                           placeholder="e.g. Chennai, Tamil Nadu" required />
                                </div>
                                <div class="col-12">
                                    <label class="form-label small fw-semibold">Investigator</label>
                                    <select name="SiteInvestigatorID" class="form-select">
                                        <option value="">Select Investigator</option>
                                        @foreach (var u in Model.Investigators)
                                        {
                                            var alreadyUsed =
                                                Model.AssignedInvestigatorIDs.Contains(u.ID);
                                            if (!alreadyUsed)
                                            {
                                                <option value="@u.ID">
                                                    @u.FullName (@u.Email)
                                                </option>
                                            }
                                            else
                                            {
                                                <option value="@u.ID" disabled>
                                                    @u.FullName (already assigned)
                                                </option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer py-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                    data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-sm btn-primary px-4">
                                Add Site
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- DELETE PROTOCOL MODAL -->
        <div class="modal fade" id="delProt-@p.ProtocolID" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content border-0 shadow-sm">
                    <div class="modal-header">
                        <h6 class="modal-title fw-semibold mb-0">Delete Protocol</h6>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body px-4 py-3">
                        <p class="small">
                            Are you sure you want to delete
                            <strong>@p.Title</strong>?
                            This will also delete all
                            <strong>@p.Sites.Count site(s)</strong>
                            attached. This cannot be undone.
                        </p>
                    </div>
                    <div class="modal-footer py-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <form method="post" asp-page-handler="DeleteProtocol">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="protocolId" value="@p.ProtocolID" />
                            <button type="submit" class="btn btn-sm btn-danger px-3">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function filterTable() {
        const val = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#protocolTable tbody tr').forEach(row => {
        row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
        });
        }
    </script>
</body>
</html>