@page
@model LifeSci360.Identity.API.Pages.Dashboard.EnrollPatientModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Enroll Patient — LifeSci360</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        .dp-wrap{position:relative}
        .dp-field{display:flex;align-items:center;border:1px solid #dee2e6;border-radius:8px;background:#fff;overflow:hidden;height:50px}
        .dp-field:hover{border-color:#0d6efd}
        .dp-text{flex:1;padding:10px 14px;font-size:15px;color:#6c757d;background:none;border:none;outline:none;cursor:default}
        .dp-text.has-val{color:#212529}
        .dp-icon-btn{padding:10px 14px;background:none;border:none;border-left:1px solid #dee2e6;cursor:pointer;color:#6c757d;display:flex;align-items:center;height:100%}
        .dp-icon-btn:hover{background:#f0f4ff;color:#0d6efd}
        .dp-popup{display:none;position:absolute;top:54px;left:0;z-index:9999;background:#fff;border:1px solid #dee2e6;border-radius:10px;padding:16px;width:290px;box-shadow:0 4px 20px rgba(0,0,0,0.12)}
        .dp-popup.open{display:block}
        .dp-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
        .dp-sel{position:relative}
        .dp-sel-btn{font-size:13px;font-weight:500;color:#212529;background:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:5px 10px;cursor:pointer;display:flex;align-items:center;gap:4px}
        .dp-sel-btn:hover{background:#e8f0fe;border-color:#0d6efd;color:#0d6efd}
        .dp-dropdown{display:none;position:absolute;top:36px;left:0;background:#fff;border:1px solid #dee2e6;border-radius:8px;z-index:100;min-width:140px;max-height:200px;overflow-y:auto;box-shadow:0 4px 16px rgba(0,0,0,0.1)}
        .dp-dropdown.open{display:block}
        .dp-opt{padding:8px 14px;font-size:13px;color:#212529;cursor:pointer}
        .dp-opt:hover{background:#f0f4ff;color:#0d6efd}
        .dp-opt.sel{color:#0d6efd;font-weight:600;background:#e8f0fe}
        .dp-nav-btn{background:#f8f9fa;border:1px solid #dee2e6;cursor:pointer;font-size:15px;color:#6c757d;padding:5px 11px;border-radius:6px}
        .dp-nav-btn:hover{background:#e8f0fe;color:#0d6efd}
        .dp-days-header{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:6px}
        .dp-dh{font-size:11px;color:#adb5bd;text-align:center;padding:4px 0;font-weight:600}
        .dp-days{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
        .dp-day{font-size:13px;text-align:center;padding:7px 2px;border-radius:50%;cursor:pointer;color:#212529}
        .dp-day:hover{background:#e8f0fe;color:#0d6efd}
        .dp-day.sel{background:#0d6efd;color:#fff;font-weight:500}
        .dp-day.empty{cursor:default;pointer-events:none}
    </style>
</head>
<body style="background:#f0f2f5;min-height:100vh">

    <nav class="navbar bg-white shadow-sm px-4">
        <span class="fw-bold text-primary">LifeSci360</span>
        <span class="text-muted small ms-2">
            / Clinical Trial Manager / Enroll Patient
        </span>
        <div class="ms-auto d-flex gap-2">
            <a asp-page="/Dashboard/ClinicalManager"
               class="btn btn-outline-secondary btn-sm">
                ← Back
                </a>
                <form method="post" asp-page="/Account/Logout">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-outline-danger btn-sm">Logout</button>
                </form>
        </div>
    </nav>

    <div class="d-flex justify-content-center align-items-center py-5">
        <div style="width:100%;max-width:680px;padding:0 16px">

            <div class="text-center mb-4">
                <h4 class="fw-semibold mb-1">Enroll New Patient</h4>
                <p class="text-muted small mb-0">
                    Fill in the patient details and assign a protocol.
                </p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 px-3 small mb-4">
                    @Model.ErrorMessage
                </div>
            }

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form method="post" asp-page-handler="Enroll">
                        @Html.AntiForgeryToken()

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Full Name
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="NewPatient.FullName"
                                       class="form-control form-control-lg"
                                       placeholder="e.g. Arjun Rajan" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Date of Birth
                                    <span class="text-danger">*</span>
                                </label>
                                <input type="hidden"
                                       asp-for="NewPatient.DateOfBirth"
                                       id="dobHidden" />
                                <div class="dp-wrap">
                                    <div class="dp-field">
                                        <span class="dp-text" id="dobText">
                                            dd mmm yyyy
                                        </span>
                                        <button type="button"
                                                class="dp-icon-btn"
                                                onclick="toggleDobPicker(event)">
                                            <svg width="18" height="18"
                                                 viewBox="0 0 16 16" fill="none">
                                                <rect x="1" y="3" width="14"
                                                      height="12" rx="2"
                                                      stroke="currentColor"
                                                      stroke-width="1.2"
                                                      fill="none"/>
                                                <path d="M1 7h14"
                                                      stroke="currentColor"
                                                      stroke-width="1.2"/>
                                                <path d="M5 1v4M11 1v4"
                                                      stroke="currentColor"
                                                      stroke-width="1.2"
                                                      stroke-linecap="round"/>
                                                <circle cx="5" cy="10" r="1"
                                                        fill="currentColor"/>
                                                <circle cx="8" cy="10" r="1"
                                                        fill="currentColor"/>
                                                <circle cx="11" cy="10" r="1"
                                                        fill="currentColor"/>
                                            </svg>
                                        </button>
                                    </div>
                                    <div class="dp-popup" id="dobPopup">
                                        <div class="dp-header">
                                            <button type="button"
                                                    class="dp-nav-btn"
                                                    onclick="event.stopPropagation();dobNav(-1)">
                                                &#8592;
                                            </button>
                                            <div style="display:flex;gap:6px">
                                                <div class="dp-sel">
                                                    <button type="button"
                                                            class="dp-sel-btn"
                                                            onclick="toggleDobDrop('m',event)">
                                                        <span id="dobML"></span>
                                                        <svg width="10" height="10"
                                                             viewBox="0 0 10 10">
                                                            <path d="M2 3l3 3 3-3"
                                                                  stroke="currentColor"
                                                                  stroke-width="1.2"
                                                                  fill="none"
                                                                  stroke-linecap="round"/>
                                                        </svg>
                                                    </button>
                                                    <div class="dp-dropdown"
                                                         id="dobMD"></div>
                                                </div>
                                                <div class="dp-sel">
                                                    <button type="button"
                                                            class="dp-sel-btn"
                                                            onclick="toggleDobDrop('y',event)">
                                                        <span id="dobYL"></span>
                                                        <svg width="10" height="10"
                                                             viewBox="0 0 10 10">
                                                            <path d="M2 3l3 3 3-3"
                                                                  stroke="currentColor"
                                                                  stroke-width="1.2"
                                                                  fill="none"
                                                                  stroke-linecap="round"/>
                                                        </svg>
                                                    </button>
                                                    <div class="dp-dropdown"
                                                         id="dobYD"></div>
                                                </div>
                                            </div>
                                            <button type="button"
                                                    class="dp-nav-btn"
                                                    onclick="event.stopPropagation();dobNav(1)">
                                                &#8594;
                                            </button>
                                        </div>
                                        <div class="dp-days-header"
                                             id="dobDH"></div>
                                        <div class="dp-days" id="dobDD"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Contact Info
                                </label>
                                <input asp-for="NewPatient.ContactInfo"
                                       class="form-control form-control-lg"
                                       placeholder="+91 98400 XXXXX" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Protocol
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="NewPatient.ProtocolID"
                                        class="form-select form-select-lg">
                                    <option value="">— Select Protocol —</option>
                                    @foreach (var p in Model.Protocols)
                                    {
                                        <option value="@p.Key">@p.Value</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-center">
                            <a asp-page="/Dashboard/ClinicalManager"
                               class="btn btn-outline-secondary btn-lg px-5">
                                Cancel
                            </a>
                            <button type="submit"
                                    class="btn btn-primary btn-lg px-5">
                                Enroll Patient
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const MS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        const MFULL=['January','February','March','April','May','June','July','August','September','October','November','December'];
        const DH=['Su','Mo','Tu','We','Th','Fr','Sa'];
        const now=new Date();
        let dY=now.getFullYear()-25,dM=now.getMonth(),dD=null;
        const dMinY=1940,dMaxY=now.getFullYear();

        function initDob(){buildDobDrops();renderDob();}

        function buildDobDrops(){
            let mh='';
            MFULL.forEach((m,i)=>mh+=`<div class="dp-opt${i===dM?' sel':''}" onclick="event.stopPropagation();dobPickM(${i})">${m}</div>`);
            document.getElementById('dobMD').innerHTML=mh;
            let yh='';
            for(let y=dMaxY;y>=dMinY;y--)
                yh+=`<div class="dp-opt${y===dY?' sel':''}" onclick="event.stopPropagation();dobPickY(${y})">${y}</div>`;
            document.getElementById('dobYD').innerHTML=yh;
        }

        function renderDob(){
            document.getElementById('dobML').textContent=MS[dM];
            document.getElementById('dobYL').textContent=dY;
            const first=new Date(dY,dM,1).getDay();
            const dim=new Date(dY,dM+1,0).getDate();
            let hh='';
            DH.forEach(d=>hh+=`<div class="dp-dh">${d}</div>`);
            document.getElementById('dobDH').innerHTML=hh;
            let h='';
            for(let i=0;i<first;i++) h+=`<div class="dp-day empty"></div>`;
            for(let d=1;d<=dim;d++){
                const iS=d===dD;
                h+=`<div class="dp-day${iS?' sel':''}" onclick="event.stopPropagation();dobPickD(${d})">${d}</div>`;
            }
            document.getElementById('dobDD').innerHTML=h;
        }

        function toggleDobPicker(e){
            e.stopPropagation();
            const p=document.getElementById('dobPopup');
            p.classList.toggle('open');
            if(p.classList.contains('open')) initDob();
        }

        function toggleDobDrop(t,e){
            e.stopPropagation();
            const id=t==='m'?'dobMD':'dobYD';
            const el=document.getElementById(id);
            const was=el.classList.contains('open');
            document.querySelectorAll('.dp-dropdown.open')
                .forEach(d=>d.classList.remove('open'));
            if(!was) el.classList.add('open');
        }

        function dobPickM(m){
            dM=m;buildDobDrops();renderDob();
            document.getElementById('dobMD').classList.remove('open');
        }
        function dobPickY(y){
            dY=y;buildDobDrops();renderDob();
            document.getElementById('dobYD').classList.remove('open');
        }
        function dobPickD(d){
            dD=d;renderDob();
            const mm=String(dM+1).padStart(2,'0');
            const dd=String(d).padStart(2,'0');
            document.getElementById('dobHidden').value=`${dY}-${mm}-${dd}`;
            const t=document.getElementById('dobText');
            t.textContent=`${d} ${MS[dM]} ${dY}`;
            t.classList.add('has-val');
            setTimeout(()=>document.getElementById('dobPopup')
                .classList.remove('open'),150);
        }
        function dobNav(dir){
            dM+=dir;
            if(dM<0){dM=11;dY--;}
            if(dM>11){dM=0;dY++;}
            buildDobDrops();renderDob();
        }

        document.addEventListener('click',e=>{
            if(!e.target.closest('.dp-wrap'))
                document.querySelectorAll('.dp-popup.open')
                    .forEach(p=>p.classList.remove('open'));
            if(!e.target.closest('.dp-sel'))
                document.querySelectorAll('.dp-dropdown.open')
                    .forEach(d=>d.classList.remove('open'));
        });
    </script>
</body>
</html>