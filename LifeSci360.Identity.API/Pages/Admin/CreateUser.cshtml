@page
@model LifeSci360.Identity.API.Pages.Admin.CreateUserModel
@{
    ViewData["Title"] = "Provision New User";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Provision User — LifeSci360</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body style="background-color: #f0f2f5; min-height: 100vh;">

    <!-- Navbar -->
    <nav class="navbar bg-white border-bottom shadow-sm px-4">
        <span class="navbar-brand fw-semibold text-primary">LifeSci360</span>
        <span class="text-muted small ms-2">/ Admin / Provision New User</span>
        <div class="ms-auto d-flex align-items-center gap-3">
            <a asp-page="/Admin/Index" class="btn btn-outline-secondary btn-sm">
                ← Back to Dashboard
            </a>
            <form method="post" asp-page="/Account/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    Logout
                </button>
            </form>
        </div>
    </nav>

    <div class="container py-4" style="max-width: 640px;">

        <!-- Page Header -->
        <div class="mb-4">
            <h5 class="fw-semibold mb-1">Provision New User</h5>
            <p class="text-muted small mb-0">
                Create a new staff account and assign their role.
                The user will log in with the temporary password you set.
            </p>
        </div>

        <!-- Success Message -->
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success d-flex align-items-center
                py-2 px-3 small mb-4" role="alert">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     fill="currentColor" class="me-2 flex-shrink-0"
                     viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                </svg>
                @Model.SuccessMessage
            </div>
        }

        <!-- Error Message -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger py-2 px-3 small mb-4" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <!-- Form Card -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="fw-semibold mb-0">User Details</h6>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div class="mb-3">
                        <label asp-for="Input.FullName"
                               class="form-label small fw-semibold">
                            Full Name
                        </label>
                        <input asp-for="Input.FullName"
                               class="form-control"
                               placeholder="e.g. Dr. Sarah Connor" />
                        <span asp-validation-for="Input.FullName"
                              class="text-danger small"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Input.Email"
                               class="form-label small fw-semibold">
                            Email Address
                        </label>
                        <input asp-for="Input.Email"
                               type="email"
                               class="form-control"
                               placeholder="e.g. sarah@lifesci360.com" />
                        <span asp-validation-for="Input.Email"
                              class="text-danger small"></span>
                    </div>

                    <!-- Phone -->
                    <div class="mb-3">
                        <label asp-for="Input.PhoneNumber"
                               class="form-label small fw-semibold">
                            Phone Number
                        </label>
                        <input asp-for="Input.PhoneNumber"
                               class="form-control"
                               placeholder="e.g. 555-0101" />
                    </div>

                    <!-- Role -->
                    <div class="mb-3">
                        <label asp-for="Input.Role"
                               class="form-label small fw-semibold">
                            Assign Role
                        </label>
                        <select asp-for="Input.Role"
                                asp-items="Model.RoleList"
                                class="form-select">
                            <option value="">— Select a role —</option>
                        </select>
                        <span asp-validation-for="Input.Role"
                              class="text-danger small"></span>
                        <div class="mt-1">
                            <small class="text-muted">
                                Role determines which dashboard and features
                                the user can access.
                            </small>
                        </div>
                    </div>

                    <!-- Role Reference -->
                    <div class="bg-light rounded p-3 mb-4 small">
                        <p class="fw-semibold mb-2 text-muted">Role Reference</p>
                        <div class="row g-1">
                            <div class="col-6">
                                <span class="badge bg-primary bg-opacity-10
                                text-primary me-1">Admin</span>
                                Full system access
                            </div>
                            <div class="col-6">
                                <span class="badge bg-primary bg-opacity-10
                                text-primary me-1">ResearchScientist</span>
                                Protocols & samples
                            </div>
                            <div class="col-6">
                                <span class="badge bg-primary bg-opacity-10
                                text-primary me-1">LabTechnician</span>
                                Lab console
                            </div>
                            <div class="col-6">
                                <span class="badge bg-primary bg-opacity-10
                                text-primary me-1">ClinicalTrialManager</span>
                                Study progress
                            </div>
                            <div class="col-6">
                                <span class="badge bg-primary bg-opacity-10
                                text-primary me-1">RegulatoryOfficer</span>
                                Audit & compliance
                            </div>
                            <div class="col-6">
                                <span class="badge bg-primary bg-opacity-10
                                text-primary me-1">DataManager</span>
                                KPIs & reporting
                            </div>
                        </div>
                    </div>

                    <!-- Temp Password -->
                    <div class="mb-4">
                        <label asp-for="Input.TempPassword"
                               class="form-label small fw-semibold">
                            Temporary Password
                        </label>
                        <input asp-for="Input.TempPassword"
                               type="password"
                               class="form-control"
                               placeholder="Min 10 chars, upper, digit, symbol" />
                        <span asp-validation-for="Input.TempPassword"
                              class="text-danger small"></span>
                        <small class="text-muted">
                            Share this with the user. They should change it on first login.
                        </small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-semibold">
                            Provision User
                        </button>
                        <a asp-page="/Admin/Index"
                               class="btn btn-outline-secondary px-4">
                            Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>