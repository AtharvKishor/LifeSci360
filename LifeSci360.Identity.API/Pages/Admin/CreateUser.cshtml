@page
@model LifeSci360.Identity.API.Pages.Admin.CreateUserModel
@{
    ViewData["Title"] = "Provision New User";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Provision New User — LifeSci360</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body style="background-color: #f0f2f5; min-height: 100vh;">

    <!-- Navbar -->
    <nav class="navbar bg-white border-bottom shadow-sm px-4">
        <span class="navbar-brand fw-semibold text-primary">LifeSci360</span>
        <span class="text-muted small ms-2">/ Admin / Provision New User</span>
        <div class="ms-auto">
            <a asp-page="/Admin/ManageUsers" class="btn btn-outline-secondary btn-sm">
                ← Back to Manage Users
            </a>
        </div>
    </nav>

    <div class="container py-5" style="max-width: 540px;">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <h5 class="fw-semibold mb-1">Provision New User</h5>
                <p class="text-muted small mb-4">
                    Create a new staff account and assign a role.
                </p>

                <!-- Error / Success -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger small">@Model.ErrorMessage</div>
                }
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success small">@Model.SuccessMessage</div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()

                    <!-- Full Name -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Full Name</label>
                        <input type="text" name="FullName"
                               class="form-control"
                               placeholder="e.g. Jane Smith"
                               value="@Model.FullName" required />
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Email Address</label>
                        <input type="email" name="Email"
                               class="form-control"
                               placeholder="e.g. jane@lifesci360.com"
                               value="@Model.Email" required />
                    </div>

                    <!-- Phone -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">
                            Phone Number
                            <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <input type="text" name="PhoneNumber"
                               class="form-control"
                               placeholder="e.g. 9876543210"
                               value="@Model.PhoneNumber" />
                    </div>

                    <!-- Role -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Role</label>
                        <select name="Role" class="form-select" required>
                            <option value="">-- Select a role --</option>
                            @foreach (var role in Model.RoleList)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                    </div>

                    <!-- Password -->
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Password</label>
                        <input type="password" name="Password"
                               class="form-control"
                               placeholder="Min 10 chars, upper, digit, symbol"
                               required />
                        <div class="form-text small text-muted">
                            Min 10 characters · uppercase · digit · special character
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="mb-4">
                        <label class="form-label small fw-semibold">
                            Confirm Password
                        </label>
                        <input type="password" name="ConfirmPassword"
                               class="form-control"
                               placeholder="Repeat password"
                               required />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Create User
                        </button>
                        <a asp-page="/Admin/ManageUsers"
                           class="btn btn-outline-secondary w-100">
                            Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>