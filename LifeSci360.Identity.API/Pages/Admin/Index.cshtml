@page
@model LifeSci360.Identity.API.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard — LifeSci360</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

</head>
<body style="background-color: #f0f2f5; min-height: 100vh;">

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-white bg-white border-bottom shadow-sm px-4">
        <span class="navbar-brand fw-semibold text-primary">LifeSci360</span>
        <div class="ms-auto d-flex align-items-center gap-3">
            <a asp-page="/Dashboard/ClinicalManager" class="btn btn-outline-primary btn-sm px-3">
                Trial Manager
            </a>
            
            <form method="post" asp-page="/Account/Login">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    Logout
                </button>
            </form>
        </div>
    </nav>

    <div class="container-fluid px-4 py-4">

        <!-- Page Header -->
        <div class="mb-4">
            <h5 class="fw-semibold mb-1">Admin Dashboard </h5>
        </div>

        <!-- Stats Cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100  text-center">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Total Users</p>
                        <h3 class="fw-semibold  mb-0">
                            @Model.TotalUsers
                        </h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100  text-center">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Active Protocols</p>
                        <h3 class="fw-semibold  mb-0">@Model.ActiveProtocols</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100  text-center">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Pending Samples</p>
                        <h3 class="fw-semibold  mb-0">@Model.PendingSamples</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm h-100  text-center">
                    <div class="card-body">
                        <p class="text-muted small mb-1">Enrolled Patients</p>
                        <h3 class="fw-semibold  mb-0">@Model.EnrolledPatients</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body d-flex gap-2 flex-wrap align-items-center">
                <span class="text-muted small me-2 fw-semibold">Quick Actions:</span>
                <a asp-page="/Admin/CreateUser" class="btn btn-primary btn-sm px-3">
                    + Provision New User
                </a>
                <a asp-page="/Admin/ManageUsers"
                       class="btn btn-outline-secondary btn-sm px-3">
                    Manage Users
                </a>
            </div>
        </div>

        <!-- Recent Users Table -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="fw-semibold mb-0">Recently Added Users</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 small fw-semibold">Full Name</th>
                                <th class="small fw-semibold">Email</th>
                                <th class="small fw-semibold">Role</th>
                                <th class="small fw-semibold">Status</th>
                                <th class="small fw-semibold">Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.RecentUsers)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary bg-opacity-10
                                                d-flex align-items-center
                                                justify-content-center"
                                                 style="width:34px; height:34px;
                                                font-size:12px; font-weight:500;
                                                color:#0d6efd;">
                                                @user.FullName.Substring(0, 1).ToUpper()
                                            </div>
                                            <span class="small fw-semibold">
                                                @user.FullName
                                            </span>
                                        </div>
                                    </td>
                                    <td class="small text-muted">@user.Email</td>
                                    <td>
                                        <span class="badge bg-primary bg-opacity-10
                                            text-primary px-2 py-1 small">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success bg-opacity-10
                                                text-success px-2 py-1 small">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10
                                                text-danger px-2 py-1 small">
                                                Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @user.CreatedDate.ToString("dd MMM yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>